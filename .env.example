# Configurações do Lakehouse (DuckDB + Parquet)
STORAGE_PATH=data/storage
DUCKDB_FILE=data/storage/cultivares.duckdb

# Configurações de API
API_LIMIT_PER_MINUTE=30
LOG_LEVEL=INFO

# Sistema de Alertas (opcional)
# Crie um bot em https://t.me/botfather e obtenha seu chat ID em https://t.me/userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# true = envia alerta mesmo quando tudo OK; false = apenas em caso de falha
ALERT_ON_SUCCESS=false
# Diretório onde os JSONs de status serão gravados (relativo ao /app do container)
LOG_STATUS_PATH=data/logs
