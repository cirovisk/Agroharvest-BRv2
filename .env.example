# Configurações do Lakehouse (DuckDB + Parquet)
STORAGE_PATH=data/storage
DUCKDB_FILE=data/storage/cultivares.duckdb

# Configurações de API
API_LIMIT_PER_MINUTE=30
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_FILE=data/logs/app.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
# CORS: origins permitidas separadas por vírgula. Deixe vazio para liberar wildcard (sem credentials).
# Exemplo: ALLOWED_ORIGINS=http://localhost:3000,https://seu-metabase.com
ALLOWED_ORIGINS=

# Sistema de Alertas (JSON Local)
# Diretório onde os JSONs de status serão gravados (relativo ao /app do container)
LOG_STATUS_PATH=data/logs
